# AlgoTest Trading Backend – Environment Configuration
# Copy this to .env and fill in your REAL credentials
# NEVER commit .env to version control — it contains secrets

# ============================================================
# Zerodha Kite Connect API Credentials
# https://kite.zerodha.com/connect/login?api_key=YOUR_API_KEY
# ============================================================
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=your_access_token_here

# Optional: auto-login credentials (not recommended for production)
# KITE_USER_ID=your_client_id
# KITE_PASSWORD=your_zerodha_password
# KITE_TOTP_SECRET=your_2fa_base32_secret

# ============================================================
# External APIs
# ============================================================
NEWS_API_KEY=your_newsapi_key_here

# ============================================================
# Application Security
# ============================================================
# Strong random API key for protecting trading endpoints
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change_me_to_long_random_string

APP_SECRET_KEY=change_this_in_production

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./algo_trading.db

# ============================================================
# Trading Configuration
# ============================================================
# Trading mode: 'paper' (simulated) or 'live' (real money)
# CRITICAL: Only set to 'live' after thorough testing
TRADING_MODE=paper

MAX_RISK_PER_TRADE=0.75
MAX_PORTFOLIO_RISK=2.0
DEFAULT_CAPITAL=1000000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Telegram Alerts (optional)
# ============================================================
# Get bot token: https://t.me/BotFather
# Get chat ID: Send /start to your bot, then curl https://api.telegram.org/botTOKEN/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================
# Strategy Toggles
# ============================================================
ENABLE_VWAP_STRATEGY=True
ENABLE_EXPIRY_SELL_STRATEGY=True

# ============================================================
# Risk & Safety Filters
# ============================================================
MIN_CONFIDENCE_THRESHOLD=60
VIX_MAX_THRESHOLD=20
VWAP_RANGE_BOUND_MAX_ORB_PCT=0.5
REENTRY_COOLDOWN_MINUTES=45
MAX_CONCURRENT_POSITIONS=3

